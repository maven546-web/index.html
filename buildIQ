<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>BuildOps — Construction Management for the Field</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
<style>
  :root {
    --ink: #0d0d0d;
    --orange: #f4500a;
    --orange-light: #ff6b2b;
    --sand: #f5f0e8;
    --warm-white: #faf8f4;
    --muted: #888070;
    --border: #e0d8cc;
    --dark-card: #141210;
    --radius: 12px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--warm-white);
    color: var(--ink);
    overflow-x: hidden;
    font-size: 16px;
    line-height: 1.6;
  }

  /* ─── NOISE TEXTURE ─── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.5;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 18px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(250,248,244,0.88);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--border);
    transition: background 0.3s;
  }

  .logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 22px;
    letter-spacing: -0.5px;
    color: var(--ink);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .logo-dot { color: var(--orange); }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 36px;
    list-style: none;
  }

  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .nav-links a:hover { opacity: 1; }

  .nav-cta {
    background: var(--ink);
    color: var(--warm-white) !important;
    opacity: 1 !important;
    padding: 10px 22px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s !important;
  }

  .nav-cta:hover { background: var(--orange) !important; }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    padding: 140px 48px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff3ed;
    border: 1px solid #ffd4bc;
    color: var(--orange);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 28px;
    animation: fadeUp 0.6s ease both;
  }

  .hero-badge::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--orange);
    border-radius: 50%;
    animation: pulse 1.6s ease infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(42px, 5vw, 68px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -2px;
    animation: fadeUp 0.7s 0.1s ease both;
    color: var(--ink);
  }

  h1 em {
    font-style: normal;
    color: var(--orange);
    position: relative;
  }

  h1 em::after {
    content: '';
    position: absolute;
    bottom: 2px; left: 0; right: 0;
    height: 3px;
    background: var(--orange);
    opacity: 0.3;
    border-radius: 2px;
  }

  .hero-sub {
    margin-top: 24px;
    font-size: 18px;
    color: #4a4540;
    max-width: 480px;
    font-weight: 400;
    line-height: 1.7;
    animation: fadeUp 0.7s 0.2s ease both;
  }

  .hero-actions {
    margin-top: 40px;
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    animation: fadeUp 0.7s 0.3s ease both;
  }

  .btn-primary {
    background: var(--orange);
    color: #fff;
    padding: 16px 32px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 24px rgba(244,80,10,0.3);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-primary:hover {
    background: var(--orange-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(244,80,10,0.4);
  }

  .btn-secondary {
    background: transparent;
    color: var(--ink);
    padding: 16px 28px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    border: 1.5px solid var(--border);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-secondary:hover {
    border-color: var(--ink);
    background: rgba(13,13,13,0.04);
  }

  .hero-trust {
    margin-top: 48px;
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 13px;
    color: var(--muted);
    animation: fadeUp 0.7s 0.4s ease both;
  }

  .trust-avatars {
    display: flex;
  }

  .trust-avatars span {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 2px solid var(--warm-white);
    margin-left: -8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
  }

  .trust-avatars span:nth-child(1) { background: #c0392b; margin-left: 0; }
  .trust-avatars span:nth-child(2) { background: #2980b9; }
  .trust-avatars span:nth-child(3) { background: #27ae60; }
  .trust-avatars span:nth-child(4) { background: #8e44ad; }

  /* ─── HERO VISUAL ─── */
  .hero-visual {
    position: relative;
    animation: fadeUp 0.8s 0.2s ease both;
  }

  .dashboard-card {
    background: var(--ink);
    border-radius: 18px;
    padding: 28px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.22), 0 0 0 1px rgba(255,255,255,0.06);
    position: relative;
    overflow: hidden;
  }

  .dashboard-card::before {
    content: '';
    position: absolute;
    top: -80px; right: -60px;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(244,80,10,0.3) 0%, transparent 70%);
    pointer-events: none;
  }

  .db-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .db-title {
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
    letter-spacing: 0.02em;
  }

  .db-dots {
    display: flex;
    gap: 6px;
  }

  .db-dots span {
    width: 8px; height: 8px;
    border-radius: 50%;
  }

  .db-dots span:nth-child(1) { background: #ff5f57; }
  .db-dots span:nth-child(2) { background: #febc2e; }
  .db-dots span:nth-child(3) { background: #28c840; }

  .db-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 20px;
  }

  .stat-box {
    background: rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 14px;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 2px;
  }

  .stat-num span { color: var(--orange); }
  .stat-label { font-size: 11px; color: rgba(255,255,255,0.45); font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; }

  .db-projects {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 20px;
  }

  .proj-row {
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(255,255,255,0.05);
    border-radius: 8px;
    padding: 12px 14px;
    border: 1px solid rgba(255,255,255,0.06);
    transition: background 0.2s;
  }

  .proj-row:hover { background: rgba(255,255,255,0.09); }

  .proj-icon {
    width: 32px; height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    flex-shrink: 0;
  }

  .proj-info { flex: 1; min-width: 0; }
  .proj-name { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.9); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .proj-sub { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 1px; }

  .proj-progress { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
  .prog-bar { width: 80px; height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; overflow: hidden; }
  .prog-fill { height: 100%; border-radius: 2px; background: var(--orange); transition: width 1s ease; }
  .prog-pct { font-size: 11px; font-weight: 700; color: var(--orange); }

  .db-alert {
    background: rgba(244,80,10,0.12);
    border: 1px solid rgba(244,80,10,0.25);
    border-radius: 8px;
    padding: 12px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .alert-icon { font-size: 16px; }
  .alert-text { font-size: 12px; color: rgba(255,255,255,0.7); }
  .alert-text strong { color: #ff8c5a; font-weight: 600; }

  .floating-card {
    position: absolute;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.15);
    padding: 14px 18px;
    border: 1px solid var(--border);
  }

  .float-1 {
    top: -24px; left: -28px;
    animation: float 3s ease-in-out infinite;
  }

  .float-2 {
    bottom: -20px; right: -24px;
    animation: float 3.5s 0.5s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
  }

  .float-label { font-size: 11px; color: var(--muted); font-weight: 500; margin-bottom: 4px; }
  .float-value { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 800; color: var(--ink); }
  .float-green { color: #16a34a; }
  .float-tag { font-size: 11px; font-weight: 600; color: #16a34a; background: #dcfce7; padding: 2px 8px; border-radius: 100px; display: inline-block; margin-top: 4px; }

  /* ─── LOGOS STRIP ─── */
  .logos-strip {
    background: var(--sand);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 28px 48px;
    text-align: center;
  }

  .logos-strip p { font-size: 12px; color: var(--muted); font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }

  .logos-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 48px;
    flex-wrap: wrap;
  }

  .logo-item {
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--muted);
    opacity: 0.6;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ─── SECTION SHARED ─── */
  .section { padding: 100px 48px; max-width: 1280px; margin: 0 auto; }
  .section-tag { font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--orange); margin-bottom: 14px; }
  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(32px, 3.5vw, 50px);
    font-weight: 800;
    letter-spacing: -1.5px;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 20px;
  }
  .section-sub { font-size: 18px; color: #5a544c; max-width: 560px; line-height: 1.7; }

  /* ─── PAIN POINTS ─── */
  .pain-section {
    background: var(--ink);
    padding: 100px 48px;
  }

  .pain-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .pain-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 60px;
    border-radius: 14px;
    overflow: hidden;
  }

  .pain-item {
    background: rgba(255,255,255,0.04);
    padding: 36px 32px;
    border: 1px solid rgba(255,255,255,0.07);
    transition: background 0.2s;
    position: relative;
  }

  .pain-item:hover { background: rgba(255,255,255,0.07); }

  .pain-emoji { font-size: 32px; margin-bottom: 16px; display: block; }
  .pain-title { font-family: 'Syne', sans-serif; font-size: 17px; font-weight: 700; color: rgba(255,255,255,0.9); margin-bottom: 10px; }
  .pain-desc { font-size: 14px; color: rgba(255,255,255,0.45); line-height: 1.7; }

  .pain-section .section-tag { color: #ff8c5a; }
  .pain-section .section-title { color: #fff; }
  .pain-section .section-sub { color: rgba(255,255,255,0.55); }

  /* ─── FEATURES ─── */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 60px;
  }

  .feature-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 36px;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
    position: relative;
    overflow: hidden;
  }

  .feature-card:hover {
    box-shadow: 0 16px 48px rgba(0,0,0,0.08);
    transform: translateY(-3px);
    border-color: var(--orange);
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--orange);
    transform: scaleX(0);
    transition: transform 0.3s;
    transform-origin: left;
  }

  .feature-card:hover::before { transform: scaleX(1); }

  .feat-icon {
    width: 52px; height: 52px;
    background: #fff3ed;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    margin-bottom: 20px;
  }

  .feat-title { font-family: 'Syne', sans-serif; font-size: 19px; font-weight: 700; color: var(--ink); margin-bottom: 10px; letter-spacing: -0.3px; }
  .feat-desc { font-size: 14px; color: #6b6057; line-height: 1.7; margin-bottom: 16px; }

  .feat-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .feat-tag {
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 100px;
    background: var(--sand);
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .feat-tag.ai { background: #fff3ed; color: var(--orange); }

  .feature-card.large { grid-column: span 2; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; }

  .feat-visual {
    background: var(--ink);
    border-radius: 12px;
    padding: 24px;
    aspect-ratio: 4/3;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }

  .feat-visual::after {
    content: '';
    position: absolute;
    bottom: -40px; right: -40px;
    width: 120px; height: 120px;
    background: radial-gradient(circle, rgba(244,80,10,0.4) 0%, transparent 70%);
  }

  .gantt-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .gantt-label { font-size: 11px; color: rgba(255,255,255,0.5); width: 80px; flex-shrink: 0; font-weight: 500; }

  .gantt-bar-wrap { flex: 1; height: 10px; background: rgba(255,255,255,0.08); border-radius: 5px; overflow: hidden; }

  .gantt-bar { height: 100%; border-radius: 5px; }

  /* ─── AI SECTION ─── */
  .ai-section {
    background: linear-gradient(135deg, #fff8f5 0%, var(--warm-white) 100%);
    padding: 100px 48px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .ai-inner { max-width: 1280px; margin: 0 auto; }

  .ai-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; margin-top: 60px; }

  .ai-features { display: flex; flex-direction: column; gap: 24px; }

  .ai-item {
    display: flex;
    gap: 16px;
    padding: 20px;
    background: #fff;
    border-radius: 12px;
    border: 1px solid var(--border);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .ai-item:hover { border-color: var(--orange); box-shadow: 0 4px 20px rgba(244,80,10,0.08); }

  .ai-icon { font-size: 28px; flex-shrink: 0; margin-top: 2px; }
  .ai-item-title { font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700; color: var(--ink); margin-bottom: 6px; }
  .ai-item-desc { font-size: 14px; color: #6b6057; line-height: 1.6; }

  .ai-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--orange);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
    margin-left: 8px;
    vertical-align: middle;
  }

  .ai-mockup {
    background: var(--ink);
    border-radius: 18px;
    padding: 28px;
    box-shadow: 0 24px 60px rgba(0,0,0,0.2);
    position: relative;
  }

  .chat-bubble {
    padding: 12px 16px;
    border-radius: 10px;
    font-size: 13px;
    line-height: 1.6;
    margin-bottom: 10px;
    max-width: 85%;
  }

  .chat-user {
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.8);
    margin-left: auto;
    border-bottom-right-radius: 3px;
    text-align: right;
  }

  .chat-ai {
    background: rgba(244,80,10,0.15);
    border: 1px solid rgba(244,80,10,0.25);
    color: rgba(255,255,255,0.85);
    border-bottom-left-radius: 3px;
  }

  .chat-ai strong { color: #ff8c5a; }

  .typing {
    display: flex;
    gap: 4px;
    padding: 12px 16px;
    background: rgba(244,80,10,0.1);
    border-radius: 10px;
    width: fit-content;
    animation: blink 1.5s ease infinite;
  }

  .typing span {
    width: 6px; height: 6px;
    background: var(--orange);
    border-radius: 50%;
  }

  .typing span:nth-child(2) { animation-delay: 0.2s; }
  .typing span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ─── PRICING ─── */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 60px;
    align-items: start;
  }

  .price-card {
    background: #fff;
    border: 1.5px solid var(--border);
    border-radius: 16px;
    padding: 36px;
    position: relative;
    transition: box-shadow 0.2s;
  }

  .price-card:hover { box-shadow: 0 16px 48px rgba(0,0,0,0.08); }

  .price-card.popular {
    background: var(--ink);
    border-color: var(--ink);
    transform: scale(1.03);
    box-shadow: 0 24px 60px rgba(0,0,0,0.2);
  }

  .popular-badge {
    position: absolute;
    top: -14px; left: 50%;
    transform: translateX(-50%);
    background: var(--orange);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 16px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .plan-name { font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin-bottom: 16px; }
  .price-card.popular .plan-name { color: rgba(255,255,255,0.5); }

  .plan-price {
    font-family: 'Syne', sans-serif;
    font-size: 48px;
    font-weight: 800;
    letter-spacing: -2px;
    color: var(--ink);
    margin-bottom: 4px;
  }

